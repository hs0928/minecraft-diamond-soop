command 별풍선 [<player>] [<integer>]:
    trigger:
        if arg-integer is 5000:
            play sound "block.anvil.place" to arg-player
            set {_rda} to random integer between 1 and 10
            add {_rda} to {다이아갯수::%uuid of arg-player%}
            send "&e별풍선 &950&e개를 후원받아 &b다이아몬드 &e%{_rda}%개가 추가되었습니다" to arg-player
        if arg-integer is 50000:
            play sound "block.anvil.place" to arg-player
            set {_rda} to random integer between 10 and 30
            add {_rda} to {다이아갯수::%uuid of arg-player%}
            send "&e별풍선 &9500&e개를 후원받아 &b다이아몬드 &e%{_rda}%개가 추가되었습니다" to arg-player
        if arg-integer is 5100:
            play sound "entity.player.levelup" with pitch 2 to arg-player
            set {_rda} to random integer between 1 and 10
            remove {_rda} from {다이아갯수::%uuid of arg-player%}
            send "&e별풍선 &951&e개를 후원받아 &b다이아몬드 &e%{_rda}%개가 차감되었습니다" to arg-player
        if arg-integer is 50100:
            play sound "entity.player.levelup" with pitch 2 to arg-player
            set {_rda} to random integer between 10 and 30
            remove {_rda} from {다이아갯수::%uuid of arg-player%}
            send "&e별풍선 &9501&e개를 후원받아 &b다이아몬드 &e%{_rda}%개가 차감되었습니다" to arg-player
        if arg-integer is 44400:
            play sound "block.anvil.place" to arg-player
            set {_r} to random integer between 1 and 100
            if {_r} is between 1 and 13:
                apply blindness 1 to arg-player for 5 seconds
                send "%nl% &b별풍선 &e444&f개를 후원받아 &8실명 &e5초&f에 걸렸습니다%nl%" to arg-player
                
                stop
            if {_r} is between 14 and 26:
                apply slowness 2 to arg-player for 5 seconds
                send "%nl% &b별풍선 &e444&f개를 후원받아 &8구속 &e5초&f에 걸렸습니다%nl%" to arg-player
                
                stop
            if {_r} is between 27 and 39:
                apply slow falling 1 to arg-player for 5 seconds
                send "%nl% &b별풍선 &e444&f개를 후원받아 &f느린낙하 &e5초&f에 걸렸습니다%nl%" to arg-player
                
                stop
            if {_r} is between 40 and 52:
                apply mining fatigue 2 to arg-player for 5 second
                send "%nl% &b별풍선 &e444&f개를 후원받아 &7채굴피로 &e5초&f에 걸렸습니다%nl%" to arg-player
                
                stop
            if {_r} is between 53 and 65:
                apply poison 1 to arg-player for 5 second
                send "%nl% &b별풍선 &e444&f개를 후원받아 &a독 &e5초&f에 걸렸습니다%nl%" to arg-player
                
                stop
            if {_r} is between 66 and 75:
                set {_mr} to random integer between 1 and 1000
                if {_mr} is between 1 and 250:
                    spawn 3 zombie at arg-player
                    send "%nl% &b별풍선 &e444&f개를 후원받아 &3좀비 3마리&f가 생성되었습니다%nl%" to arg-player
                    
                    stop
                if {_mr} is between 251 and 450:
                    spawn 3 skeleton at arg-player
                    send "%nl% &b별풍선 &e444&f개를 후원받아 &7스켈레톤 3마리&f가 생성되었습니다%nl%" to arg-player
                    
                    stop
                if {_mr} is between 451 and 650:
                    spawn 3 spider at arg-player
                    send "%nl% &b별풍선 &e444&f개를 후원받아 &8거미 3마리&f가 생성되었습니다%nl%" to arg-player
                    stop
                if {_mr} is between 651 and 850:
                    spawn 2 creeper at arg-player
                    send "%nl% &b별풍선 &e444&f개를 후원받아 &a크리퍼 2마리&f가 생성되었습니다%nl%" to arg-player
                    stop
                if {_mr} is between 851 and 950:
                    spawn 1 witch at arg-player
                    send "%nl% &b별풍선 &e444&f개를 후원받아 &d마녀 1마리&f가 생성되었습니다%nl%" to arg-player
                    stop
                if {_mr} is between 951 and 1000:
                    spawn 1 vindicator at arg-player
                    send "%nl% &b별풍선 &e444&f개를 후원받아 &7변명자 1마리&f가 생성되었습니다%nl%" to arg-player
                    stop
            if {_r} is between 76 and 85:
                while 1 is 1:
                    set {_px} to arg-player's x-coord
                    set {_pz} to arg-player's z-coord
                    set {_x} to random integer between {_px}-500 and {_px}+500
                    set {_z} to random integer between {_pz}-500 and {_pz}+500
                    set {_y} to 250
                    while block at location at {_x}, {_y}, {_z} is air:
                        remove 1 from {_y}
                    if block at location at {_x}, {_y}, {_z} is not water:
                        teleport arg-player to location({_x}+0.5, {_y}+1, {_z}+0.5, world("world")) 
                        
                        send "%nl% &b별풍선 &e444&f개를 후원받아 랜덤 좌표로 텔레포트 되었습니다%nl%" to arg-player
                        stop
            if {_r} is between 86 and 95:
                add 1 to {인벤제한::%uuid of arg-player%}
                set {인벤제한유무::%uuid of arg-player%} to true
                send "%nl% &b별풍선 &e444&f개를 후원받아 인벤토리 한칸이 금지되었습니다%nl%" to arg-player
            if {_r} is between 96 and 100:
                set {_rss} to random integer between 1 and 36
                set slot {_rss}-1 of inventory of arg-player to air
                
                send "%nl% &b별풍선 &e444&f개를 후원받아 인벤토리 한칸에 있던 아이템이 제거되었습니다%nl%" to arg-player
                stop
        if arg-integer is 33300:
            set {_r2} to random integer between 1 and 100
            if {_r2} is between 1 and 30:
                apply speed 1 to arg-player for 5 seconds
                send "%nl% &b별풍선 &e333&f개를 후원받아 &b신속 &e5초&f에 걸렸습니다%nl%" to arg-player
                play sound "entity.player.levelup" to arg-player
                stop
            if {_r2} is between 31 and 60:
                apply haste 2 to arg-player for 5 seconds
                send "%nl% &b별풍선 &e333&f개를 후원받아 &e성급함 &e5초&f에 걸렸습니다%nl%" to arg-player
                play sound "entity.player.levelup" to arg-player
                stop
            if {_r2} is between 61 and 90:
                apply regeneration 1 to arg-player for 5 seconds
                send "%nl% &b별풍선 &e333&f개를 후원받아 &c재생 &e5초&f에 걸렸습니다%nl%" to arg-player
                play sound "entity.player.levelup" to arg-player
                stop
            if {_r2} is between 91 and 100:
                set {_rda} to random integer between 1 and 10
                send "%nl% &b별풍선 &e333&f개를 후원받아 &b다이아몬드 &f%{_rda}%개를 얻으셨습니다%nl%" to arg-player
                give {_rda} of diamond to arg-player
                play sound "entity.player.levelup" to arg-player
                stop
        if arg-integer is 444400:
            set {별풍4444::%uuid of arg-player%} to true
            set {_p} to arg-player's location
            kill the arg-player
            send "%nl% &e%arg-player%님이 &b별풍선 &64&f,&e4&24&94&f개를 후원받아 즉사하셨습니다%nl%" to all players
            play sound "ui.toast.challenge_complete" with volume 1 with pitch 1 to all players
            create safe explosion of force 5 at {_p}
            strike lightning effect at {_p}
            loop 5 times:
                launch flickering ball large coloured red, green and yellow fading to light green and black at {_p} with duration 4
                wait 1 tick

every 20 tick:
    loop all players:
        if {인벤제한유무::%uuid of loop-player%} is true:
            delete {인벤제한유무::%uuid of loop-player%}
            wait 1 tick
            wait 600 second
            remove 1 from {인벤제한::%uuid of loop-player%}

every 19 tick:
    add 0 to {다이아갯수}
    add 0 to {다이아제출갯수}
    loop all players:
        add 0 to {다이아갯수::%uuid of loop-player%}
        add 0 to {다이아제출갯수::%uuid of loop-player%}
        #set {다이아보유::%uuid of loop-player%} to amount of diamond in inventory of loop-player
        wipe loop-player's sidebar
        set name of sidebar of loop-player to "&e정보"
        set score "&e캐야하는 다이아 갯수(전체) : %{다이아갯수}-{다이아제출갯수}%" in sidebar of loop-player to 2
        set score "&e캐야하는 다이아 갯수(개인) : %{다이아갯수::%uuid of loop-player%}-{다이아제출갯수::%uuid of loop-player%}%" in sidebar of loop-player to 3
        set score "&e보유한 다이아 수 : %amount of diamond in inventory of loop-player%" in sidebar of loop-player to 1
        set score "&e인벤토리 슬롯제한 : %{인벤제한::%uuid of loop-player%}%" in sidebar of loop-player to 0
        #delete {lsc}
        #wait 1 tick
        #loop size of {관리자제외전체인원::*} times:
            #add 1 to {lsc}
            #set score "&e%{관리자제외전체인원::%{lsc}%}%님이 보유한 다이아 수 : %{다이아보유::%uuid of {관리자제외전체인원::%{lsc}%}%}%" in sidebar of loop-player to 0

#every 1 second:
