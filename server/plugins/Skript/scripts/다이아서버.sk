command z전체다이아제출갯수초기화:
    trigger:
        if player is op:
            delete {다이아제출갯수}

command z개인다이아제출갯수초기화:
    trigger:
        if player is op:
            delete {다이아제출갯수::*}

command z전체다이아갯수초기화:
    trigger:
        if player is op:
            delete {다이아갯수}

command z개인다이아갯수초기화:
    trigger:
        if player is op:
            delete {다이아갯수::*}

command z전체다이아갯수설정 [<integer>]:
    trigger:
        if player is op:
            set {다이아갯수} to arg-integer

on inventory click:
    if event-item is barrier named "&c잠긴 슬롯":
        cancel event

command z인벤제한확인 [<player>]:
    trigger:
        if player is op:
            send "%arg-player%님의 인벤제한 : %{인벤제한::%uuid of arg-player%}%" to player

on join:
    add 0 to {인벤제한::%uuid of player%}

every 1 second:
    console command "clear @a barrier"
    console command "kill @e[type=item,nbt={Item:{id:""minecraft:barrier""}}]"
    loop all players:
        wait 1 tick
        set {_limit} to {인벤제한::%uuid of loop-player%}
        if {_limit} is not 0:
            loop numbers from 0 to {_limit} - 1:
                set slot loop-number+9 of loop-player's inventory to barrier named "&c잠긴 슬롯"

on drop:
    if event-item is barrier:
        wait 1 tick
        console command "kill @e[type=item,nbt={Item:{id:""minecraft:barrier""}}]"

on break of any ore:
    set player's level to player's level + 1

command 다이아제출 [<text>] [<integer>]:
    trigger:
        if arg-text is "전체" or "개인":
            if arg-integer is set:
                set {_da} to amount of diamond in inventory of player
                if {_da} >= arg-integer:
                    if arg-text is "전체":
                        add arg-integer to {다이아제출갯수}
                    if arg-text is "개인":
                        add arg-integer to {다이아제출갯수::%uuid of player%}
                    send "&e다이아몬드 %arg-integer%개를 제출하였습니다" to player
                    play sound "entity.player.levelup" with pitch 2 to player
                    remove arg-integer of diamond from player's inventory
                else:
                    send "&c다이아몬드 %arg-integer%개 혹은 그 이상을 보유하고 있지 않습니다" to player
                    play sound "entity.enderman.teleport" to player
        else:
            send "&c명령어사용법 : /다이아제출 [전체/개인] [갯수]" to player

on rightclick on entity:
    if name of entity is "도박":
        set {도박창염::%uuid of player%} to true
        open chest with 3 rows named "도박" to player
        play sound "entity.experience_orb.pickup" to player
        set {_s} to 0
        loop 27 times:
            set slot {_s} of current inventory of player to light blue stained glass pane named " "
            add 1 to {_s}
        set slot 13 of current inventory of player to air
        set slot 22 of current inventory of player to itemsadder item "_iainternal:icon_right_blue" named "&a도박"

#command 도박:
#    trigger:
#        set {도박창염::%uuid of player%} to true
#        open chest with 3 rows named "도박" to player
#        play sound "entity.experience_orb.pickup" to player
#        set {_s} to 0
#        loop 27 times:
#            set slot {_s} of current inventory of player to light blue stained glass pane named " "
#            add 1 to {_s}
#        set slot 13 of current inventory of player to air
#        set slot 22 of current inventory of player to itemsadder item "_iainternal:icon_right_blue" named "&a도박"

on inventory close:
    if {도박창염::%uuid of player%} is true:
        if slot 13 of current inventory of player is not air:
            set {_s13i} to slot 13 of current inventory of player
            give {_s13i} to player
        delete {도박창염::%uuid of player%}

on inventory click:
    if inventory name is "도박":
        if event-item is not diamond:
            if clicked slot is not air:
                cancel event
                if clicked slot is 22:
                    if clicked inventory is not player's inventory:
                        if slot 13 of current inventory of player is diamond:
                            set {도박아이템::%uuid of player%} to slot 13 of current inventory of player
                            wait 1 tick
                            set {s2} to 0
                            loop 6 times:
                                play sound "entity.experience_orb.pickup" to player
                                set {s} to 0
                                loop 27 times:
                                    set slot {s} of current inventory of player to {유리판%{s2}%} named " "
                                    set slot 13 of current inventory of player to {도박템%{s2}%}
                                    add 1 to {s}
                                add 1 to {s2}
                                wait 2 tick
                            wait 1 tick
                            set {s2} to 0
                            loop 6 times:
                                play sound "entity.experience_orb.pickup" to player
                                set {s} to 0
                                loop 27 times:
                                    set slot {s} of current inventory of player to {유리판%{s2}%} named " "
                                    set slot 13 of current inventory of player to {도박템%{s2}%}
                                    add 1 to {s}
                                add 1 to {s2}
                                wait 3 tick
                            wait 1 tick
                            set {s2} to 0
                            loop 6 times:
                                play sound "entity.experience_orb.pickup" to player
                                set {s} to 0
                                loop 27 times:
                                    set slot {s} of current inventory of player to {유리판%{s2}%} named " "
                                    set slot 13 of current inventory of player to {도박템%{s2}%}
                                    add 1 to {s}
                                add 1 to {s2}
                                wait 4 tick
                            wait 1 tick
                            delete {도박창염::%uuid of player%}
                            wait 1 tick
                            set {_rdbi} to random integer between 1 and 100
                            if {_rdbi} is between 1 and 70:
                                send "&c꽝!" to player
                                play sound "block.anvil.place" to player
                            if {_rdbi} is between 71 and 90:
                                send "&a2배!" to player
                                play sound "entity.experience_orb.pickup" to player
                                loop 2 times:
                                    give {도박아이템::%uuid of player%} to player
                            if {_rdbi} is between 91 and 100:
                                send "&a3배!" to player
                                play sound "entity.player.levelup" to player
                                loop 3 times:
                                    give {도박아이템::%uuid of player%} to player
                            wait 1 tick
                            close player's inventory
                            delete {도박아이템::%uuid of player%}
                        else:
                            send "&c다이아몬드를 넣어주세요" to player

on rightclick on entity:
    if name of entity is "상점":
        play sound "entity.experience_orb.pickup" to player
        open chest with 3 rows named "상점" to player
        set slot 10 of current inventory of player to itemsadder item "ab:save" with lore "&e비용 : &c레드스톤 &e10개"
        set slot 11 of current inventory of player to baked potato with lore "&e비용 : &8석탄 &e1개"
        set slot 13 of current inventory of player to {수선책} with lore "&e비용 : &b다이아몬드 &e20개"
        set slot 14 of current inventory of player to {효율책} with lore "&e비용 : &b다이아몬드 &e10개"
        set slot 15 of current inventory of player to {내구책} with lore "&e비용 : &b다이아몬드 &e10개"
        set slot 16 of current inventory of player to {행운책} with lore "&e비용 : &b다이아몬드 &e10개"

