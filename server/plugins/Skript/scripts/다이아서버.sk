#        set slot 15 of current inventory of player to {내구책} with lore "&e비용 : &b다이아몬드 &e10개"
#        set slot 16 of current inventory of player to {행운책} with lore "&e비용 : &b다이아몬드 &e10개"

on inventory click:
    if inventory name is "상점":
        cancel event
        if clicked inventory is not player's inventory:
            if clicked slot is 10:
                set {_ra} to amount of redstone in inventory of player
                if {_ra} >= 10:
                    give itemsadder item "ab:save" to player
                    send "&e인벤세이브권을 성공적으로 구매하였습니다" to player
                    play sound "entity.experience_orb.pickup" to player
                    remove 10 redstone from player's inventory
                else:
                    send "&c인벤세이브권을 구매하기 위한 비용이 부족합니다" to player
                    play sound "entity.enderman.teleport" to player
            if clicked slot is 11:
                set {_ca} to amount of coal in inventory of player
                if {_ca} >= 1:
                    give baked potato to player
                    send "&e구운감자를 성공적으로 구매하였습니다" to player
                    play sound "entity.experience_orb.pickup" to player
                    remove 1 coal from player's inventory
                else:
                    send "&c구운감자를를 구매하기 위한 비용이 부족합니다" to player
                    play sound "entity.enderman.teleport" to player
            if clicked slot is 13:
                set {_da} to amount of diamond in inventory of player
                if {_da} >= 20:
                    give {수선책} to player
                    send "&e인첸트북을 성공적으로 구매하였습니다" to player
                    play sound "entity.experience_orb.pickup" to player
                    remove 20 diamond from player's inventory
                else:
                    send "&c인첸트북을 구매하기 위한 비용이 부족합니다" to player
                    play sound "entity.enderman.teleport" to player
            if clicked slot is 14:
                set {_da} to amount of diamond in inventory of player
                if {_da} >= 10:
                    give {효율책} to player
                    send "&e인첸트북을 성공적으로 구매하였습니다" to player
                    play sound "entity.experience_orb.pickup" to player
                    remove 20 diamond from player's inventory
                else:
                    send "&c인첸트북을 구매하기 위한 비용이 부족합니다" to player
                    play sound "entity.enderman.teleport" to player
            if clicked slot is 15:
                set {_da} to amount of diamond in inventory of player
                if {_da} >= 10:
                    give {내구책} to player
                    send "&e인첸트북을 성공적으로 구매하였습니다" to player
                    play sound "entity.experience_orb.pickup" to player
                    remove 20 diamond from player's inventory
                else:
                    send "&c인첸트북을 구매하기 위한 비용이 부족합니다" to player
                    play sound "entity.enderman.teleport" to player
            if clicked slot is 16:
                set {_da} to amount of diamond in inventory of player
                if {_da} >= 10:
                    give {행운책} to player
                    send "&e인첸트북을 성공적으로 구매하였습니다" to player
                    play sound "entity.experience_orb.pickup" to player
                    remove 20 diamond from player's inventory
                else:
                    send "&c인첸트북을 구매하기 위한 비용이 부족합니다" to player
                    play sound "entity.enderman.teleport" to player

on death of player:
    if {별풍4444::%uuid of victim%} is not true:
        if victim has itemsadder item "ab:save":
            keep inventory
            cancel drops
            remove itemsadder item "ab:save" from victim's inventory
    wait 5 tick
    delete {별풍4444::%uuid of victim%}

command 귀환:
    trigger:
        set {_spawn} to location at -99.5, 79, 665.5 in world "world"
        set pitch of {_spawn} to 0
        set yaw of {_spawn} to 90
        teleport player to {_spawn}
        #teleport player to location at -99.5, 79, 665.5 in world "world"

on first join:
    wait 10 tick
    set {_spawn} to location at -99.5, 79, 665.5 in world "world"
    set pitch of {_spawn} to 0
    set yaw of {_spawn} to 90
    teleport player to {_spawn}
    console command "spawnpoint %player% -99.5 79 665.5"

command 공지 [<text>]:
    trigger:
        if player is op:
            send "%nl%&7&l<&e &l공지 &7&l> &r&e%arg-text%%nl%" to all players
