#    trigger:
#        open chest with 3 rows named "상점" to player
#        set slot 10 of current inventory of player to itemsadder item "ab:save" with lore "&e비용 : &c레드스톤 &e10개"
#        set slot 11 of current inventory of player to baked potato with lore "&e비용 : &8석탄 &e1개"
